# Whitelist: only curated, original content goes public
/*
!/.gitignore
!/README.md
!/index.html
!/Companies/
!/Placement Training/

# Claude Code teaching skills are public; the rest of .claude/ stays private
!/.claude/
/.claude/*
!/.claude/skills/

# Resumes, JDs, third-party/personal docs stay private
Companies/**/*.pdf
Companies/**/*.docx
Companies/**/*.doc

# Copyrighted books and tool metadata
Placement Training/APTITUDE/
Placement Training/.claude/
Placement Training/.remember/
Placement Training/CLAUDE.md

# OS junk
Thumbs.db
desktop.ini
.DS_Store
~$*
